{
  "name": "@askrjs/auth",
  "version": "0.0.1",
  "description": "Shared authentication contracts and request auth resolution for Askr",
  "keywords": ["askr", "authentication", "authorization", "oidc"],
  "homepage": "https://github.com/askrjs/askr-auth#readme",
  "bugs": { "url": "https://github.com/askrjs/askr-auth/issues" },
  "repository": { "type": "git", "url": "git+https://github.com/askrjs/askr-auth.git" },
  "author": { "name": "askrjs", "url": "https://github.com/askrjs" },
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jwt": {
      "types": "./dist/jwt.d.ts",
      "import": "./dist/jwt.js"
    },
    "./oidc": {
      "types": "./dist/oidc.d.ts",
      "import": "./dist/oidc.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist/**/*.js", "dist/**/*.d.ts"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "vp pack",
    "lint": "vp lint src tests && npm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vp test run -c vitest.config.ts",
    "test:publint": "publint",
    "pack:check": "npm pack --ignore-scripts --dry-run --json",
    "check": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:publint && npm run pack:check",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "publint": "^0.3.21",
    "typescript": "^6.0.0",
    "vite-plus": "^0.2.4",
    "vitest": "^4.0.0"
  },
  "engines": { "node": ">=18" }
}
